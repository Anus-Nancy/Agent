SECRET_KEY=super-secret-key
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/tcf
ACCESS_TOKEN_EXPIRE_MINUTES=60
ESCALATION_CHECK_INTERVAL_MINUTES=10
